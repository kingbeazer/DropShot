    private void OpenSeedDivisionsDialog()
    {
        _seedSourceCompetitionId = _seedSourceCandidates.FirstOrDefault()?.CompetitionID;
        _seedApplyPromotion = false;
        _seedPromoteCount = 0;
        _seedDemoteCount = 0;
        _showSeedDivisionsDialog = true;
    }

    private async Task RunSeedDivisions()
    {
        if (!_seedSourceCompetitionId.HasValue) return;
        _seedingDivisions = true;
        try
        {
            await using var db = DbFactory.CreateDbContext();
            var previous = await db.Competition
                .Include(c => c.Divisions)
                .Include(c => c.Participants)
                .FirstOrDefaultAsync(c => c.CompetitionID == _seedSourceCompetitionId.Value);
            if (previous == null)
            {
                Snackbar.Add("Previous competition not found.", Severity.Error);
                return;
            }
            var comp = await db.Competition
                .Include(c => c.Divisions)
                .Include(c => c.Participants)
                .FirstOrDefaultAsync(c => c.CompetitionID == Id);
            if (comp == null) return;

            if (comp.Divisions.Any())
            {
                Snackbar.Add("This competition already has divisions — clear them first.", Severity.Error);
                return;
            }

            var byRank = new Dictionary<byte, CompetitionDivision>();
            foreach (var prev in previous.Divisions.OrderBy(d => d.Rank))
            {
                var nd = new CompetitionDivision
                {
                    CompetitionId = Id,
                    Rank = prev.Rank,
                    Name = prev.Name
                };
                db.CompetitionDivisions.Add(nd);
                byRank[prev.Rank] = nd;
            }
            comp.HasDivisions = true;
            comp.SeededFromCompetitionId = previous.CompetitionID;
            await db.SaveChangesAsync();

            var previousRankByPlayer = previous.Participants
                .Where(p => p.CompetitionDivisionId.HasValue)
                .ToDictionary(
                    p => p.PlayerId,
                    p => previous.Divisions.First(d => d.CompetitionDivisionId == p.CompetitionDivisionId).Rank);

            if (_seedApplyPromotion && (_seedPromoteCount > 0 || _seedDemoteCount > 0))
            {
                byte minRank = previous.Divisions.Min(d => d.Rank);
                byte maxRank = previous.Divisions.Max(d => d.Rank);
                var stats = await PlayerStatsService.ComputeAsync(db, new[] { previous.CompetitionID }, previous.LeagueScoring);
                foreach (var div in previous.Divisions)
                {
                    var ranked = previous.Participants
                        .Where(p => p.CompetitionDivisionId == div.CompetitionDivisionId)
                        .Select(p => new { p.PlayerId, Points = stats.TryGetValue(p.PlayerId, out var s) ? s.LeaguePoints : 0 })
                        .OrderByDescending(x => x.Points)
                        .ToList();
                    if (div.Rank > minRank)
                    {
                        foreach (var promo in ranked.Take(_seedPromoteCount))
                            previousRankByPlayer[promo.PlayerId] = (byte)(div.Rank - 1);
                    }
                    if (div.Rank < maxRank)
                    {
                        foreach (var demo in ranked.AsEnumerable().Reverse().Take(_seedDemoteCount))
                            previousRankByPlayer[demo.PlayerId] = (byte)(div.Rank + 1);
                    }
                }
            }

            int assigned = 0;
            foreach (var cp in comp.Participants)
            {
                if (!previousRankByPlayer.TryGetValue(cp.PlayerId, out var nextRank)) continue;
                if (!byRank.TryGetValue(nextRank, out var div)) continue;
                cp.CompetitionDivisionId = div.CompetitionDivisionId;
                assigned++;
            }
            await db.SaveChangesAsync();

            _divisions = byRank.Values.OrderBy(d => d.Rank).ToList();
            foreach (var cp in comp.Participants)
            {
                var local = _participants.FirstOrDefault(p => p.PlayerId == cp.PlayerId);
                if (local != null) local.CompetitionDivisionId = cp.CompetitionDivisionId;
            }
            Model.HasDivisions = true;
            Model.SeededFromCompetitionId = previous.CompetitionID;

            Snackbar.Add($"Seeded {byRank.Count} division(s); assigned {assigned} participant(s).", Severity.Success);
            _showSeedDivisionsDialog = false;
        }
        finally
        {
            _seedingDivisions = false;
        }
    }

    private Task ValidateTeam(CompetitionTeam team)
    {
        var members = _participants
            .Where(p => p.TeamId == team.CompetitionTeamId
                && p.Status == ParticipantStatus.FullPlayer)
            .ToList();

        var errors = new List<string>();
        var requiredRoles = _availableRoles;

        if (requiredRoles.Count > 0)
        {
            foreach (var role in requiredRoles)
            {
                int count = members.Count(m => m.Role == role);
                if (count == 0) errors.Add($"Missing role {role}");
                else if (count > 1) errors.Add($"Duplicate role {role}");
            }
            foreach (var m in members.Where(m => string.IsNullOrEmpty(m.Role)))
                errors.Add($"{m.Player?.DisplayName}: no role");
        }

        if (errors.Count == 0)
            Snackbar.Add($"{team.Name}: Valid", Severity.Success);
        else
            Snackbar.Add($"{team.Name}: {string.Join("; ", errors)}", Severity.Warning);

        return Task.CompletedTask;
    }

