    private async Task LoadRubberTemplateStateAsync(MyDbContext db, int competitionId, string? persistedKey)
    {
        _rubberPresets = RubberTemplateRegistry.AvailablePresets().ToList();

        var comp = await db.Competition
            .AsNoTracking()
            .Include(c => c.RubberTemplate)
                .ThenInclude(t => t!.Rubbers)
            .FirstOrDefaultAsync(c => c.CompetitionID == competitionId);

        if (comp?.RubberTemplate is { Rubbers.Count: > 0 })
        {
            _rubberTemplateSource = "custom";
            _selectedRubberPresetKey = null;
        }
        else if (!string.IsNullOrEmpty(persistedKey))
        {
            _rubberTemplateSource = "preset";
            _selectedRubberPresetKey = persistedKey;
        }
        else
        {
            _rubberTemplateSource = "default";
            _selectedRubberPresetKey = null;
        }

        var template = await RubberTemplateProvider.GetAsync(db, competitionId);
        _rubberTemplateDefs = template?.ToList() ?? [];
        _availableRoles = RubberTemplateRegistry.GetRoleSet(template).ToList();
    }

    private async Task ReloadRubberTemplateAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        var comp = await db.Competition.AsNoTracking().FirstOrDefaultAsync(c => c.CompetitionID == Id);
        await LoadRubberTemplateStateAsync(db, Id, comp?.RubberTemplateKey);
    }

    private async Task ApplyRubberPreset(string? key)
    {
        await using var db = DbFactory.CreateDbContext();
        var comp = await db.Competition.FindAsync(Id);
        if (comp == null) return;
        comp.RubberTemplateKey = string.IsNullOrWhiteSpace(key) ? null : key;
        // Removing a custom template ensures preset takes effect
        var custom = await db.CompetitionRubberTemplates.FirstOrDefaultAsync(t => t.CompetitionId == Id);
        if (custom != null) db.CompetitionRubberTemplates.Remove(custom);
        await db.SaveChangesAsync();
        await ReloadRubberTemplateAsync();
        Snackbar.Add("Rubber preset applied.", Severity.Success);
    }

    private async Task ConvertToCustomTemplate()
    {
        // Snapshot the currently-resolved template into a custom one so the user can edit.
        if (_rubberTemplateDefs.Count == 0) return;
        await using var db = DbFactory.CreateDbContext();
        var comp = await db.Competition
            .Include(c => c.RubberTemplate).ThenInclude(t => t!.Rubbers)
            .FirstOrDefaultAsync(c => c.CompetitionID == Id);
        if (comp == null) return;

        if (comp.RubberTemplate == null)
        {
            comp.RubberTemplate = new CompetitionRubberTemplate { CompetitionId = Id };
            db.CompetitionRubberTemplates.Add(comp.RubberTemplate);
        }
        else
        {
            db.RubberTemplateRubbers.RemoveRange(comp.RubberTemplate.Rubbers);
            comp.RubberTemplate.Rubbers.Clear();
        }

        int order = 1;
        foreach (var def in _rubberTemplateDefs)
        {
            comp.RubberTemplate.Rubbers.Add(new RubberTemplateRubber
            {
                Order = order++,
                Name = def.Name,
                CourtNumber = def.CourtNumber,
                HomeRoles = def.HomeRoles.ToList(),
                AwayRoles = def.AwayRoles.ToList(),
            });
        }
        await db.SaveChangesAsync();
        await ReloadRubberTemplateAsync();
        Snackbar.Add("Template snapshot saved. You can now edit it.", Severity.Success);
    }

    private async Task AddCustomRubberRow()
    {
        await using var db = DbFactory.CreateDbContext();
        var template = await db.CompetitionRubberTemplates
            .Include(t => t.Rubbers)
            .FirstOrDefaultAsync(t => t.CompetitionId == Id);
        if (template == null) return;

        int nextOrder = template.Rubbers.Count == 0 ? 1 : template.Rubbers.Max(r => r.Order) + 1;
        template.Rubbers.Add(new RubberTemplateRubber
        {
            Order = nextOrder,
            Name = "Rubber " + nextOrder,
            CourtNumber = 1,
            HomeRoles = ["A"],
            AwayRoles = ["A"],
        });
        await db.SaveChangesAsync();
        await ReloadRubberTemplateAsync();
    }

    private void OpenRubberRowEditor(RubberDef row)
    {
        _editingRubberRow = row;
        _editingRubberName = row.Name;
        _editingRubberCourt = row.CourtNumber;
        _editingRubberHomeCsv = string.Join(", ", row.HomeRoles);
        _editingRubberAwayCsv = string.Join(", ", row.AwayRoles);
        _showRubberRowDialog = true;
    }

    private async Task SaveRubberRowDialog()
    {
        if (_editingRubberRow == null) { _showRubberRowDialog = false; return; }

        await using var db = DbFactory.CreateDbContext();
        var row = await db.RubberTemplateRubbers
            .Include(r => r.Template)
            .FirstOrDefaultAsync(r => r.Template.CompetitionId == Id && r.Order == _editingRubberRow.Order);
        if (row != null)
        {
            row.Name = string.IsNullOrWhiteSpace(_editingRubberName) ? row.Name : _editingRubberName.Trim();
            row.CourtNumber = _editingRubberCourt < 1 ? 1 : _editingRubberCourt;
            row.HomeRoles = ParseRoles(_editingRubberHomeCsv);
            row.AwayRoles = ParseRoles(_editingRubberAwayCsv);
            await db.SaveChangesAsync();
        }

        _showRubberRowDialog = false;
        _editingRubberRow = null;
        await ReloadRubberTemplateAsync();
    }

    private async Task DeleteCustomRubberRow(int order)
    {
        await using var db = DbFactory.CreateDbContext();
        var row = await db.RubberTemplateRubbers
            .Include(r => r.Template)
            .FirstOrDefaultAsync(r => r.Template.CompetitionId == Id && r.Order == order);
        if (row == null) return;
        db.RubberTemplateRubbers.Remove(row);
        await db.SaveChangesAsync();
        await ReloadRubberTemplateAsync();
    }

