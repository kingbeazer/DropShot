    private void DownloadImportTemplate()
    {
        if (_playersClub is null) return;
        NavigationManager.NavigateTo($"/api/clubs/{_playersClub.ClubId}/players/import-template", forceLoad: true);
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        _importParseError = null;
        _importPreviewRows = [];
        _importErrors = [];

        var file = e.File;
        if (file is null) return;
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            _importParseError = "Please select a .csv file.";
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            var (rows, errors) = ParseImportCsv(stream);
            _importPreviewRows = rows;
            _importErrors = errors;
            if (rows.Count == 0 && errors.Count == 0)
                _importParseError = "The file contains no data rows.";
        }
        catch (Exception ex)
        {
            _importParseError = $"Could not read file: {ex.Message}";
        }
    }

    private async Task ConfirmImport()
    {
        if (_playersClub is null || _importPreviewRows.Count == 0) return;
        _importRunning = true;

        int imported = 0, skipped = 0;
        foreach (var row in _importPreviewRows)
        {
            if (string.IsNullOrWhiteSpace(row.DisplayName)) { skipped++; continue; }
            try
            {
                await PlayerService.CreateLightPlayerAsync(_playersClub.ClubId,
                    new CreateLightPlayerRequest(
                        row.DisplayName.Trim(), row.FirstName, row.LastName,
                        row.Email, row.MobileNumber, row.DateOfBirth, row.Sex));
                imported++;
            }
            catch
            {
                skipped++;
            }
        }

        _importRunning = false;
        _showImportDialog = false;
        _importPreviewRows = [];
        _importErrors = [];
        SiteAlerts.Add($"Import complete: {imported} added, {skipped} skipped.", Severity.Success);
        await LoadClubPlayers();
    }

    private void CancelImport()
    {
        _showImportDialog = false;
        _importPreviewRows = [];
        _importErrors = [];
        _importParseError = null;
    }

    private static (List<PlayerImportRow> Rows, List<string> Errors) ParseImportCsv(Stream stream)
    {
        var rows = new List<PlayerImportRow>();
        var errors = new List<string>();
        using var reader = new System.IO.StreamReader(stream);

        var header = reader.ReadLine();
        if (header is null) return (rows, errors);

        int lineNum = 1;
        string? line;
        while ((line = reader.ReadLine()) != null)
        {
            lineNum++;
            if (string.IsNullOrWhiteSpace(line)) continue;
            var parts = SplitCsvLine(line);

            string? Get(int i) => parts.Length > i && !string.IsNullOrWhiteSpace(parts[i]) ? parts[i].Trim() : null;

            var displayName = Get(0);
            if (string.IsNullOrWhiteSpace(displayName))
            {
                errors.Add($"Line {lineNum}: DisplayName is required — row skipped.");
                continue;
            }

            DateOnly? dob = null;
            if (Get(5) is string dobStr)
            {
                if (DateOnly.TryParseExact(dobStr, "dd/MM/yyyy", null,
                        System.Globalization.DateTimeStyles.None, out var parsed))
                    dob = parsed;
                else
                    errors.Add($"Line {lineNum}: '{dobStr}' is not a valid date (use dd/MM/yyyy) — date ignored.");
            }

            PlayerSex? sex = null;
            if (Get(6) is string sexStr)
            {
                if (Enum.TryParse<PlayerSex>(sexStr, ignoreCase: true, out var s))
                    sex = s;
                else
                    errors.Add($"Line {lineNum}: '{sexStr}' is not a valid Sex value (Male/Female/Other) — sex ignored.");
            }

            rows.Add(new PlayerImportRow(displayName, Get(1), Get(2), Get(3), Get(4), dob, sex));
        }
        return (rows, errors);
    }

    private static string[] SplitCsvLine(string line)
    {
        var parts = new List<string>();
        bool inQuotes = false;
        var current = new System.Text.StringBuilder();
        foreach (char c in line)
        {
            if (c == '"') inQuotes = !inQuotes;
            else if (c == ',' && !inQuotes) { parts.Add(current.ToString()); current.Clear(); }
            else current.Append(c);
        }
        parts.Add(current.ToString());
        return [.. parts];
    }

    private static string? NullIfEmpty(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();
