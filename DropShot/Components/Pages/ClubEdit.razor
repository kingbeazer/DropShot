    private async Task OpenAddRulesSetDialog()
    {
        var parameters = new DialogParameters<DropShot.UI.Components.Pages.RulesSetCreateDialog>
        {
            { x => x.ClubId, ClubId }
        };
        var dialog = await DialogService.ShowAsync<DropShot.UI.Components.Pages.RulesSetCreateDialog>(
            "Add Rules Set", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadRulesSets();
    }

    private void StartEditRulesSet(RulesSet set)
    {
        _editingRulesSet = set;
        _editRulesSetForm = new RulesSetForm { Name = set.Name, Description = set.Description };
        _showEditRulesSetDialog = true;
    }

    private async Task SaveEditRulesSet()
    {
        if (_editingRulesSet == null || string.IsNullOrWhiteSpace(_editRulesSetForm.Name)) return;
        await using var dbc = DbFactory.CreateDbContext();
        var r = await dbc.RulesSets.FindAsync(_editingRulesSet.RulesSetId);
        if (r == null) return;
        r.Name = _editRulesSetForm.Name.Trim();
        r.Description = NullIfEmpty(_editRulesSetForm.Description);
        await dbc.SaveChangesAsync();
        _showEditRulesSetDialog = false;
        SiteAlerts.Add("Rules set updated.", Severity.Success);
        await LoadRulesSets();
    }

    private async Task DeleteRulesSet(RulesSet set)
    {
        await using var dbc = DbFactory.CreateDbContext();
        var r = await dbc.RulesSets.FindAsync(set.RulesSetId);
        if (r != null) { dbc.RulesSets.Remove(r); await dbc.SaveChangesAsync(); }
        SiteAlerts.Add("Rules set deleted.", Severity.Warning);
        await LoadRulesSets();
    }

    private string GetNewRuleText(int rulesSetId) =>
        _newRuleTextByRulesSet.TryGetValue(rulesSetId, out var v) ? v : "";

    private void SetNewRuleText(int rulesSetId, string value) =>
        _newRuleTextByRulesSet[rulesSetId] = value;

    private async Task AddRuleItem(RulesSet set)
    {
        var text = GetNewRuleText(set.RulesSetId);
        if (string.IsNullOrWhiteSpace(text)) return;
        await using var dbc = DbFactory.CreateDbContext();
        var nextOrder = set.Items.Count == 0 ? 1 : set.Items.Max(i => i.SortOrder) + 1;
        dbc.RulesSetItems.Add(new RulesSetItem
        {
            RulesSetId = set.RulesSetId,
            SortOrder = nextOrder,
            RuleText = text.Trim()
        });
        await dbc.SaveChangesAsync();
        _newRuleTextByRulesSet[set.RulesSetId] = "";
        SiteAlerts.Add("Rule added.", Severity.Success);
        await LoadRulesSets();
    }

    private async Task DeleteRuleItem(RulesSet set, RulesSetItem item)
    {
        await using var dbc = DbFactory.CreateDbContext();
        var i = await dbc.RulesSetItems.FindAsync(item.RulesSetItemId);
        if (i != null) { dbc.RulesSetItems.Remove(i); await dbc.SaveChangesAsync(); }
        SiteAlerts.Add("Rule removed.", Severity.Warning);
        await LoadRulesSets();
    }

    private static string? NullIfEmpty(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();
}
