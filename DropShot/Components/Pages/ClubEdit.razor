@page "/clubs/{ClubId:int}/edit"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DropShot.Models
@using DropShot.Data
@using DropShot.Shared
@using DropShot.Shared.Dtos
@using DropShot.Shared.Extensions
@using CourtSurface = DropShot.Shared.CourtSurface
@inject IDbContextFactory<MyDbContext> DbFactory
@inject IClubService ClubService
@inject ICurrentUser CurrentUser
@inject ISiteAlertService SiteAlerts
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject DropShot.UI.Services.IPlayerService PlayerService

<MudProviders />

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_notFound)
{
    <MudText Typo="Typo.h5" Class="mb-4">Club not found.</MudText>
    <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo("/clubs"))">Back to Clubs</MudButton>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" aria-label="Back to clubs"
                       OnClick="@(() => Nav.NavigateTo("/clubs"))" />
        <MudText Typo="Typo.h4">@_club!.Name</MudText>
    </MudStack>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4 frosted-card mt-2">

        @* ── Details tab ─────────────────────────────────────────── *@
        <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
            <MudGrid Spacing="2" Style="max-width:600px">
                <MudItem xs="12">
                    <MudTextField @bind-Value="_detailsForm.Name" Label="Club Name" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_detailsForm.AddressLine1" Label="Address Line 1" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_detailsForm.AddressLine2" Label="Address Line 2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_detailsForm.Town" Label="Town" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_detailsForm.Postcode" Label="Postcode" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_detailsForm.Phone" Label="Phone" Variant="Variant.Outlined"
                                  InputType="InputType.Telephone" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_detailsForm.Email" Label="Email" Variant="Variant.Outlined"
                                  InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_detailsForm.Website" Label="Website" Variant="Variant.Outlined"
                                  InputType="InputType.Url" />
                </MudItem>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDetails"
                               Disabled="string.IsNullOrWhiteSpace(_detailsForm.Name)">
                        Save Details
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ── Courts tab ───────────────────────────────────────────── *@
        <MudTabPanel Text="Courts" Icon="@Icons.Material.Filled.SportsTennis">
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="4">
                    <MudTextField @bind-Value="_courtForm.Name" Label="Court Name" Variant="Variant.Outlined"
                                  Placeholder="e.g. Court 1" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudSelect @bind-Value="_courtForm.Surface" T="CourtSurface" Label="Surface" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (CourtSurface s in Enum.GetValues<CourtSurface>())
                        {
                            <MudSelectItem T="CourtSurface" Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="3">
                    <MudCheckBox @bind-Value="_courtForm.IsIndoor" Label="Indoor" />
                </MudItem>
                <MudItem xs="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddCourt" Disabled="string.IsNullOrWhiteSpace(_courtForm.Name)">Add</MudButton>
                </MudItem>
            </MudGrid>

            <MudTable Items="@_courts" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Surface</MudTh>
                    <MudTh>Indoor</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    @if (_editingCourtId == context.CourtId)
                    {
                        <MudTd>
                            <MudTextField @bind-Value="_courtEditForm.Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudTd>
                        <MudTd>
                            <MudSelect @bind-Value="_courtEditForm.Surface" T="CourtSurface" Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (CourtSurface s in Enum.GetValues<CourtSurface>())
                                {
                                    <MudSelectItem T="CourtSurface" Value="@s">@s</MudSelectItem>
                                }
                            </MudSelect>
                        </MudTd>
                        <MudTd>
                            <MudCheckBox @bind-Value="_courtEditForm.IsIndoor" />
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Save" Size="Size.Small" Color="Color.Primary"
                                           OnClick="SaveEditCourt"
                                           Disabled="string.IsNullOrWhiteSpace(_courtEditForm.Name)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small"
                                           OnClick="@(() => _editingCourtId = null)" />
                        </MudTd>
                    }
                    else
                    {
                        <MudTd>@context.Name</MudTd>
                        <MudTd>@context.Surface</MudTd>
                        <MudTd><MudIcon Icon="@(context.IsIndoor ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)" Size="Size.Small" /></MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => StartEditCourt(context))"
                                           Disabled="_editingCourtId is not null" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteCourt(context))"
                                           Disabled="_editingCourtId is not null" />
                        </MudTd>
                    }
                </RowTemplate>
                <NoRecordsContent><MudText Typo="Typo.caption">No courts yet.</MudText></NoRecordsContent>
            </MudTable>
        </MudTabPanel>

        @* ── Scheduling Templates tab ─────────────────────────────── *@
        <MudTabPanel Text="Scheduling Templates" Icon="@Icons.Material.Filled.Schedule">
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="9">
                    <MudTextField @bind-Value="_newTemplateName" Label="Template Name" Variant="Variant.Outlined"
                                  Placeholder="e.g. Weekday evenings" />
                </MudItem>
                <MudItem xs="3" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddTemplate" Disabled="string.IsNullOrWhiteSpace(_newTemplateName)">Add</MudButton>
                </MudItem>
            </MudGrid>

            @foreach (var template in _templates)
            {
                <MudPaper Class="pa-3 mb-3" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.subtitle2">@template.Name</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteTemplate(template))" />
                    </MudStack>

                    <MudGrid Spacing="1" Class="mb-2">
                        <MudItem xs="4">
                            <MudSelect T="DayOfWeek" @bind-Value="_newWindowDay[template.ClubSchedulingTemplateId]" Label="Day"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (DayOfWeek d in Enum.GetValues<DayOfWeek>())
                                {
                                    <MudSelectItem T="DayOfWeek" Value="@d">@d</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="3">
                            <MudTimePicker @bind-Time="_newWindowStart[template.ClubSchedulingTemplateId]"
                                           Label="From" Variant="Variant.Outlined" Margin="Margin.Dense" AmPm="false" />
                        </MudItem>
                        <MudItem xs="3">
                            <MudTimePicker @bind-Time="_newWindowEnd[template.ClubSchedulingTemplateId]"
                                           Label="To" Variant="Variant.Outlined" Margin="Margin.Dense" AmPm="false" />
                        </MudItem>
                        <MudItem xs="2" Class="d-flex align-center">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       OnClick="@(() => AddTemplateWindow(template))">Add</MudButton>
                        </MudItem>
                    </MudGrid>

                    @if (template.Windows.Count > 0)
                    {
                        <MudSimpleTable Dense="true">
                            <thead>
                                <tr><th>Day</th><th>From</th><th>To</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var w in template.Windows)
                                {
                                    <tr>
                                        <td>@w.DayOfWeek</td>
                                        <td>@w.StartTime.ToString(@"hh\:mm")</td>
                                        <td>@w.EndTime.ToString(@"hh\:mm")</td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Color="Color.Error" OnClick="@(() => DeleteTemplateWindow(template, w))" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">No windows defined yet.</MudText>
                    }
                </MudPaper>
            }

            @if (_templates.Count == 0)
            {
                <MudText Typo="Typo.caption">No templates yet. Add one above.</MudText>
            }
        </MudTabPanel>

        @* ── Competition Templates tab ────────────────────────────── *@
        <MudTabPanel Text="Competition Templates" Icon="@Icons.Material.Filled.EmojiEvents">
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="9">
                    <MudTextField @bind-Value="_newCompTemplateName" Label="Template Name" Variant="Variant.Outlined"
                                  Placeholder="e.g. Standard Singles" />
                </MudItem>
                <MudItem xs="3" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddCompetitionTemplate" Disabled="string.IsNullOrWhiteSpace(_newCompTemplateName)">Add</MudButton>
                </MudItem>
            </MudGrid>

            @foreach (var ct in _competitionTemplatesList)
            {
                <MudPaper Class="pa-3 mb-3" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.subtitle2">@ct.Name</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteCompetitionTemplate(ct))" />
                    </MudStack>
                    <MudGrid Spacing="1" Class="mb-2">
                        <MudItem xs="6" sm="3">
                            <MudSelect T="CompetitionFormat?" @bind-Value="ct.Format" Label="Format" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                @foreach (CompetitionFormat f in Enum.GetValues<CompetitionFormat>())
                                {
                                    <MudSelectItem T="CompetitionFormat?" Value="@((CompetitionFormat?)f)">@f.ToDisplayName()</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudNumericField @bind-Value="ct.BestOf" Label="Best Of" Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Max="5" />
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudNumericField @bind-Value="ct.MaxAge" Label="Max Age" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => SaveCompetitionTemplate(ct))">Save</MudButton>
                        </MudItem>
                    </MudGrid>
                    <MudGrid Spacing="1" Class="mb-2">
                        <MudItem xs="4">
                            <MudSelect T="DayOfWeek" @bind-Value="_newCTWindowDay[ct.CompetitionTemplateId]" Label="Day"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (DayOfWeek d in Enum.GetValues<DayOfWeek>())
                                {
                                    <MudSelectItem T="DayOfWeek" Value="@d">@d</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="3">
                            <MudTimePicker @bind-Time="_newCTWindowStart[ct.CompetitionTemplateId]"
                                           Label="From" Variant="Variant.Outlined" Margin="Margin.Dense" AmPm="false" />
                        </MudItem>
                        <MudItem xs="3">
                            <MudTimePicker @bind-Time="_newCTWindowEnd[ct.CompetitionTemplateId]"
                                           Label="To" Variant="Variant.Outlined" Margin="Margin.Dense" AmPm="false" />
                        </MudItem>
                        <MudItem xs="2" Class="d-flex align-center">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       OnClick="@(() => AddCTWindow(ct))">Add</MudButton>
                        </MudItem>
                    </MudGrid>
                    @if (ct.Windows.Count > 0)
                    {
                        <MudSimpleTable Dense="true">
                            <thead><tr><th>Day</th><th>From</th><th>To</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var w in ct.Windows)
                                {
                                    <tr>
                                        <td>@w.DayOfWeek</td>
                                        <td>@w.StartTime.ToString(@"hh\:mm")</td>
                                        <td>@w.EndTime.ToString(@"hh\:mm")</td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                           Color="Color.Error" OnClick="@(() => DeleteCTWindow(ct, w))" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">No windows defined.</MudText>
                    }
                </MudPaper>
            }
            @if (_competitionTemplatesList.Count == 0)
            {
                <MudText Typo="Typo.caption">No competition templates yet. Add one above.</MudText>
            }
        </MudTabPanel>

        @* ── Email Templates tab ──────────────────────────────────── *@
        <MudTabPanel Text="Email Templates" Icon="@Icons.Material.Filled.Email">
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="12" sm="5">
                    <MudTextField @bind-Value="_newEmailTemplateName" Label="Template Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudTextField @bind-Value="_newEmailTemplateSubject" Label="Subject" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_newEmailTemplateBody" Label="Body" Variant="Variant.Outlined"
                                  Lines="3" HelperText="Variables: {PlayerName}, {CompetitionName}, {MatchLink}" />
                </MudItem>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddEmailTemplate"
                               Disabled="@(string.IsNullOrWhiteSpace(_newEmailTemplateName) || string.IsNullOrWhiteSpace(_newEmailTemplateSubject))">
                        Add Template
                    </MudButton>
                </MudItem>
            </MudGrid>

            @foreach (var et in _emailTemplatesList)
            {
                <MudPaper Class="pa-3 mb-3" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <div>
                            <MudText Typo="Typo.subtitle2">@et.Name</MudText>
                            <MudText Typo="Typo.caption"><strong>Subject:</strong> @et.Subject</MudText>
                            <MudText Typo="Typo.caption" Style="white-space:pre-wrap">@(et.Body.Length > 100 ? et.Body[..100] + "…" : et.Body)</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteEmailTemplate(et))" />
                    </MudStack>
                </MudPaper>
            }
            @if (_emailTemplatesList.Count == 0)
            {
                <MudText Typo="Typo.caption">No email templates yet. Add one above.</MudText>
            }
        </MudTabPanel>

        @* ── Rules tab ────────────────────────────────────────────── *@
        <MudTabPanel Text="Rules" Icon="@Icons.Material.Filled.Gavel">
            <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddRulesSetDialog">Add Rules Set</MudButton>
            </MudStack>

            @foreach (var set in _rulesSets)
            {
                <MudPaper Class="pa-3 mb-3" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <div>
                            <MudText Typo="Typo.subtitle2">@set.Name</MudText>
                            @if (!string.IsNullOrWhiteSpace(set.Description))
                            {
                                <MudText Typo="Typo.caption">@set.Description</MudText>
                            }
                        </div>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => StartEditRulesSet(set))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteRulesSet(set))" />
                        </MudStack>
                    </MudStack>

                    <MudStack Row="true" Spacing="2" Class="mb-2" AlignItems="AlignItems.Center">
                        <MudTextField Value="@GetNewRuleText(set.RulesSetId)"
                                      ValueChanged="@((string v) => SetNewRuleText(set.RulesSetId, v))"
                                      T="string"
                                      Label="Rule"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex:1"
                                      Placeholder="e.g. Sets played first to 6" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => AddRuleItem(set))">Add Rule</MudButton>
                    </MudStack>

                    @if (set.Items.Count == 0)
                    {
                        <MudText Typo="Typo.caption">No rules yet.</MudText>
                    }
                    else
                    {
                        <MudTable Items="@set.Items.OrderBy(i => i.SortOrder).ToList()" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>Rule</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.SortOrder</MudTd>
                                <MudTd>@context.RuleText</MudTd>
                                <MudTd>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => DeleteRuleItem(set, context))" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            }
            @if (_rulesSets.Count == 0)
            {
                <MudText Typo="Typo.caption">No rules sets yet for this club. Add one above.</MudText>
            }
        </MudTabPanel>

        @* ── Players tab ──────────────────────────────────────────── *@
        <MudTabPanel Text="Players" Icon="@Icons.Material.Filled.People">
            <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Download"
                           OnClick="DownloadImportTemplate">
                    Download Template
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Upload"
                           OnClick="@(() => _showImportDialog = true)">
                    Import Players
                </MudButton>
                <MudSpacer />
                <MudToggleGroup T="bool" @bind-Value="_showArchivedPlayers">
                    <MudToggleItem Value="false">Active</MudToggleItem>
                    <MudToggleItem Value="true">Archived</MudToggleItem>
                </MudToggleGroup>
            </MudStack>

            @if (_playersLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else
            {
                var filtered = _clubPlayers.Where(p => p.IsActive == !_showArchivedPlayers).ToList();
                <MudTable Items="@filtered" Dense="true" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Player</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Email</MudTh>
                        <MudTh>Mobile</MudTh>
                        <MudTh Style="width:110px;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Player">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@(context.IsLight ? Icons.Material.Filled.PersonOutline : Icons.Material.Filled.Person)"
                                         Size="Size.Small" Color="@(context.IsLight ? Color.Default : Color.Primary)" />
                                <span>@context.DisplayName</span>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Type">
                            @if (context.IsLight)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">Light</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Full</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Email">@(context.Email ?? "—")</MudTd>
                        <MudTd DataLabel="Mobile">@(context.MobileNumber ?? "—")</MudTd>
                        <MudTd DataLabel="Actions">
                            <MudStack Row="true" Spacing="1">
                                @if (context.IsActive)
                                {
                                    <MudTooltip Text="Archive">
                                        <MudIconButton Icon="@Icons.Material.Filled.Archive" Size="Size.Small"
                                                       Color="Color.Warning"
                                                       OnClick="@(() => ArchivePlayer(context))" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudTooltip Text="Unarchive">
                                        <MudIconButton Icon="@Icons.Material.Filled.Unarchive" Size="Size.Small"
                                                       Color="Color.Success"
                                                       OnClick="@(() => UnarchivePlayer(context))" />
                                    </MudTooltip>
                                }
                                @if (!context.IsActive || context.IsClubOwned)
                                {
                                    <MudTooltip Text="Delete">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DeletePlayer(context))" />
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.caption">
                            @(_showArchivedPlayers ? "No archived players." : "No active players.")
                        </MudText>
                    </NoRecordsContent>
                </MudTable>
            }
        </MudTabPanel>

    </MudTabs>

    @* ── Import Players Dialog ───────────────────────────────────── *@
    <MudDialog @bind-Visible="_showImportDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>Import Players</TitleContent>
        <DialogContent>
            @if (_importPreviewRows.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mb-3">
                    Select a CSV file to import. Download the template to see the required column format.
                    Columns: <strong>DisplayName, FirstName, LastName, Email, MobileNumber, DateOfBirth (dd/MM/yyyy), Sex (Male/Female/Other)</strong>.
                </MudText>
                <InputFile id="importFileInput" OnChange="OnImportFileSelected" accept=".csv" style="display:none;" />
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AttachFile"
                           HtmlTag="label" for="importFileInput">
                    Select CSV file
                </MudButton>
                @if (!string.IsNullOrEmpty(_importParseError))
                {
                    <MudAlert Severity="Severity.Error" Class="mt-2">@_importParseError</MudAlert>
                }
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mb-2">
                    <strong>@_importPreviewRows.Count</strong> player@(_importPreviewRows.Count == 1 ? "" : "s") found. Review and confirm to import.
                </MudText>
                <MudTable Items="@_importPreviewRows" Dense="true" Elevation="0" Style="max-height:320px;overflow-y:auto;">
                    <HeaderContent>
                        <MudTh>Display Name</MudTh>
                        <MudTh>First</MudTh>
                        <MudTh>Last</MudTh>
                        <MudTh>Email</MudTh>
                        <MudTh>DOB</MudTh>
                        <MudTh>Sex</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.DisplayName</MudTd>
                        <MudTd>@(context.FirstName ?? "—")</MudTd>
                        <MudTd>@(context.LastName ?? "—")</MudTd>
                        <MudTd>@(context.Email ?? "—")</MudTd>
                        <MudTd>@(context.DateOfBirth?.ToString("dd/MM/yyyy") ?? "—")</MudTd>
                        <MudTd>@(context.Sex?.ToString() ?? "—")</MudTd>
                    </RowTemplate>
                </MudTable>

                @if (_importErrors.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Class="mt-2">
                        @_importErrors.Count row@(_importErrors.Count == 1 ? "" : "s") will be skipped:
                        <ul class="mt-1">
                            @foreach (var err in _importErrors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    </MudAlert>
                }
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CancelImport">Cancel</MudButton>
            @if (_importPreviewRows.Count > 0)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@_importRunning"
                           OnClick="ConfirmImport">
                    @if (_importRunning)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Import @_importPreviewRows.Count @(_importPreviewRows.Count == 1 ? "player" : "players")
                </MudButton>
            }
        </DialogActions>
    </MudDialog>

    @* ── Edit Rules Set Name Dialog ────────────────────────────── *@
    <MudDialog @bind-Visible="_showEditRulesSetDialog">
        <TitleContent>Edit Rules Set</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="_editRulesSetForm.Name" Label="Name" Variant="Variant.Outlined"
                          Required="true" Class="mb-3" />
            <MudTextField @bind-Value="_editRulesSetForm.Description" Label="Description (optional)"
                          Variant="Variant.Outlined" Lines="3" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showEditRulesSetDialog = false)">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEditRulesSet">Save</MudButton>
        </DialogActions>
    </MudDialog>
}

