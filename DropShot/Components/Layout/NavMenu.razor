@implements IDisposable

@inject NavigationManager NavigationManager

<div class="top-row navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <img src="/Images/Logo.png" class="navbar-logo" alt="DropShot Logo" />
            DropShot
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <MudIcon Icon="@Icons.Material.Filled.Home" Class="nav-icon" /> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="match">
                <MudIcon Icon="@Icons.Material.Filled.SportsTennis" Class="nav-icon" /> Match
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="score">
                <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Class="nav-icon" /> Scoreboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="competitions">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="nav-icon" /> Competitions
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="players">
                <MudIcon Icon="@Icons.Material.Filled.People" Class="nav-icon" /> Players
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="clubs">
                <MudIcon Icon="@Icons.Material.Filled.Business" Class="nav-icon" /> Clubs
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="rules">
                <MudIcon Icon="@Icons.Material.Filled.Gavel" Class="nav-icon" /> Rules
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="auth">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Class="nav-icon" /> Auth Required
            </NavLink>
        </div>

        <AuthorizeView Roles="Admin,SuperAdmin,ClubAdmin">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="display-control">
                    <MudIcon Icon="@Icons.Material.Filled.ScreenShare" Class="nav-icon" /> Display Control
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView Roles="Admin,SuperAdmin">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/users">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="nav-icon" /> User Management
                </NavLink>
            </div>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="friends">
                        <MudIcon Icon="@Icons.Material.Filled.Group" Class="nav-icon" /> Friends
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="nav-icon" /> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <MudIcon Icon="@Icons.Material.Filled.Logout" Class="nav-icon" /> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="nav-icon" /> Register
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <MudIcon Icon="@Icons.Material.Filled.Login" Class="nav-icon" /> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

