<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Model.DisplayName" Label="Display / Nick Name"
                          Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="Model.FirstName" Label="First Name"
                          Variant="Variant.Outlined" />
            <MudTextField @bind-Value="Model.LastName" Label="Last Name"
                          Variant="Variant.Outlined" />
            <MudTextField @bind-Value="Model.Email" Label="Email"
                          InputType="InputType.Email" Variant="Variant.Outlined" />
            <MudDatePicker @bind-Date="Model.DateOfBirth" Label="Date of Birth"
                           Variant="Variant.Outlined" MaxDate="DateTime.Today"
                           Editable="true" DateFormat="dd/MM/yyyy" />
            <MudSelect @bind-Value="Model.Sex" Label="Sex" Variant="Variant.Outlined"
                       T="PlayerSex?" Clearable="true">
                @foreach (PlayerSex s in Enum.GetValues<PlayerSex>())
                {
                    <MudSelectItem Value="(PlayerSex?)s">@s</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="string.IsNullOrWhiteSpace(Model.DisplayName)"
                   OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public PlayerFormModel Model { get; set; } = new();
    [Parameter] public int? PlayerId { get; set; }

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(Model));
}
