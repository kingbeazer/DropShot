@using DropShot.Shared
@using DropShot.Shared.Dtos
@using DropShot.UI.Services

<MudPaper id="section-fixture-reminders" Class="pa-4 setup-section frosted-card" Elevation="0"
          Style="color: white;">
    <MudText Typo="Typo.h6" Class="mb-1">Fixture reminder emails</MudText>
    <MudText Typo="Typo.caption" Style="opacity:0.75" Class="d-block mb-3">
        Each reminder is sent automatically X hours before the fixture's scheduled time.
        Use <strong>{PlayerName}</strong>, <strong>{OpponentName}</strong>,
        <strong>{CompetitionName}</strong>, <strong>{MatchDate}</strong>,
        <strong>{MatchLink}</strong>, and <strong>{ResultLink}</strong> as placeholders.
        The <strong>{ResultLink}</strong> variable is only available when "Include result link" is enabled.
    </MudText>

    @if (Reminders.Count > 0)
    {
        <MudSimpleTable Dense="true" Class="mb-3">
            <thead>
                <tr>
                    <th>Hours before</th>
                    <th>Subject</th>
                    <th>Result link</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Reminders)
                {
                    var rem = r;
                    <tr>
                        <td>@rem.HoursBefore h</td>
                        <td>@rem.Subject</td>
                        <td>
                            @if (rem.IncludeResultLink)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small" />
                            }
                        </td>
                        <td>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => StartEdit(rem))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => OnDeleteReminder.InvokeAsync(rem.CompetitionFixtureReminderId))" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        @if (!_editing)
        {
            <MudStack Row="true" Spacing="2" Class="mb-1">
                <MudButton Size="Size.Small" Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="StartAdd">Add reminder</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.RestartAlt"
                           OnClick="ResetToDefault">Reset to default</MudButton>
            </MudStack>
        }
    }
    else if (!_editing)
    {
        @* Show read-only default template preview *@
        <MudPaper Elevation="0" Class="pa-3 mb-3"
                  Style="border:1px solid rgba(255,255,255,0.15);border-radius:8px;opacity:0.85;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Style="opacity:0.7" />
                <MudText Typo="Typo.caption" Style="opacity:0.7">Default email template — configure timing below to activate</MudText>
            </MudStack>
            <MudText Typo="Typo.caption" Class="d-block"><strong>Subject:</strong> @FixtureReminderDefaults.Subject</MudText>
            <MudText Typo="Typo.caption" Class="d-block mt-1" Style="white-space:pre-wrap"><strong>Body:</strong>&#10;@FixtureReminderDefaults.Body</MudText>
            <MudText Typo="Typo.caption" Class="d-block mt-1">
                <strong>Result link:</strong>
                @if (FixtureReminderDefaults.IncludeResultLink)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" Style="vertical-align:middle" />
                    <span> Included</span>
                }
                else
                {
                    <span>Not included</span>
                }
            </MudText>
        </MudPaper>

        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Edit"
                   OnClick="StartOverride">Override email configuration</MudButton>
    }

    @if (_editing)
    {
        <MudPaper Elevation="0" Class="pa-3 mb-3"
                  Style="border:1px solid rgba(255,255,255,0.15);border-radius:8px;">
            <MudText Typo="Typo.subtitle2" Class="mb-2">@(_editId.HasValue ? "Edit reminder" : "Custom reminder")</MudText>

            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int" @bind-Value="_editHours"
                                     Label="Hours before match"
                                     Min="1" Max="720"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField T="string" @bind-Value="_editSubject"
                                  Label="Email subject"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" @bind-Value="_editBody"
                                  Label="Email body (Markdown supported, use {variables})"
                                  Variant="Variant.Outlined" Lines="6"
                                  HelperText="{PlayerName}, {OpponentName}, {CompetitionName}, {MatchDate}, {MatchLink}, {ResultLink}" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox @bind-Value="_editIncludeResultLink"
                                 Label="Include result submission link ({ResultLink})"
                                 Dense="true" />
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Spacing="2" Class="mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           Disabled="@(_editHours < 1 || string.IsNullOrWhiteSpace(_editSubject) || string.IsNullOrWhiteSpace(_editBody))"
                           OnClick="SaveEdit">
                    @(_editId.HasValue ? "Save" : "Save override")
                </MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CancelEdit">Cancel</MudButton>
            </MudStack>
        </MudPaper>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CompetitionFixtureReminderDto> Reminders { get; set; } = [];
    [Parameter] public EventCallback<SaveFixtureReminderRequest> OnAddReminder { get; set; }
    [Parameter] public EventCallback<(int ReminderId, SaveFixtureReminderRequest Request)> OnUpdateReminder { get; set; }
    [Parameter] public EventCallback<int> OnDeleteReminder { get; set; }

    private bool _editing;
    private int? _editId;
    private int _editHours;
    private string _editSubject = "";
    private string _editBody = "";
    private bool _editIncludeResultLink = FixtureReminderDefaults.IncludeResultLink;

    private void StartAdd()
    {
        _editId = null;
        _editHours = 0;
        _editSubject = "";
        _editBody = "";
        _editIncludeResultLink = FixtureReminderDefaults.IncludeResultLink;
        _editing = true;
    }

    private void StartOverride()
    {
        _editId = null;
        _editHours = 0;
        _editSubject = FixtureReminderDefaults.Subject;
        _editBody = FixtureReminderDefaults.Body;
        _editIncludeResultLink = FixtureReminderDefaults.IncludeResultLink;
        _editing = true;
    }

    private void StartEdit(CompetitionFixtureReminderDto r)
    {
        _editId = r.CompetitionFixtureReminderId;
        _editHours = r.HoursBefore;
        _editSubject = r.Subject;
        _editBody = r.Body;
        _editIncludeResultLink = r.IncludeResultLink;
        _editing = true;
    }

    private void CancelEdit() => _editing = false;

    private async Task SaveEdit()
    {
        var req = new SaveFixtureReminderRequest(_editHours, _editSubject.Trim(), _editBody.Trim(), _editIncludeResultLink);
        if (_editId.HasValue)
            await OnUpdateReminder.InvokeAsync((_editId.Value, req));
        else
            await OnAddReminder.InvokeAsync(req);
        _editing = false;
    }

    private async Task ResetToDefault()
    {
        foreach (var r in Reminders.ToList())
            await OnDeleteReminder.InvokeAsync(r.CompetitionFixtureReminderId);
    }
}
