@inject IClubService ClubService
@inject ICurrentUser CurrentUser
@inject ISiteAlertService SiteAlerts
@inject IDialogService DialogService
@inject NavigationManager Nav

<MudText Typo="Typo.h4" Class="mb-4">Clubs</MudText>

@if (CurrentUser.IsAdmin)
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenAddDialog" Class="mb-4">
        Add Club
    </MudButton>
}

<MudTextField @bind-Value="_searchText" Placeholder="Search clubs..."
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true" Class="mb-4" />

<MudTable Items="@_clubs" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading"
          Filter="@(club => FilterClubs(club))"
          Class="frosted-card" Elevation="0">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Town</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Courts</MudTh>
        <MudTh>Link Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Town">@(context.Town ?? "—")</MudTd>
        <MudTd DataLabel="Email">@(context.Email ?? "—")</MudTd>
        <MudTd DataLabel="Courts">@context.CourtCount</MudTd>
        <MudTd DataLabel="Link Status">
            @{
                var status = GetStatus(context.ClubId);
            }
            @switch (status)
            {
                case ClubLinkState.Administered:
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Admin</MudChip>
                    break;
                case ClubLinkState.AdminPending:
                    <div style="display: inline-flex; align-items: center; gap: 4px;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Admin Request Pending</MudChip>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       aria-label="Cancel admin request"
                                       OnClick="@(() => CancelAdminRequest(context))" />
                    </div>
                    break;
                case ClubLinkState.Linked:
                    <div style="display: inline-flex; align-items: center; gap: 4px;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Linked</MudChip>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                   OnClick="@(() => RequestAdminRole(context))">
                            Request Admin
                        </MudButton>
                    </div>
                    break;
                case ClubLinkState.Pending:
                    <div style="display: inline-flex; align-items: center; gap: 4px;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Request Pending</MudChip>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       aria-label="Cancel link request"
                                       OnClick="@(() => CancelRequest(context))" />
                    </div>
                    break;
                default:
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                               OnClick="@(() => RequestLink(context))">
                        Request to Link
                    </MudButton>
                    break;
            }
        </MudTd>
        <MudTd DataLabel="Actions">
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                           aria-label="View club" Href="@($"/clubs/{context.ClubId}")" />
            @{
                var canAdminThis = CurrentUser.IsAdmin || _adminClubIds.Contains(context.ClubId);
            }
            @if (canAdminThis)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/clubs/{context.ClubId}/edit"))" />
            }
            @if (CurrentUser.IsAdmin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteClub(context))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No clubs yet.</MudText>
    </NoRecordsContent>
</MudTable>

@* ── Add Club Dialog ──────────────────────────────────── *@
<MudDialog @bind-Visible="_showClubDialog">
    <TitleContent>Add Club</TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudTextField @bind-Value="_clubForm.Name" Label="Club Name" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_clubForm.AddressLine1" Label="Address Line 1" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_clubForm.AddressLine2" Label="Address Line 2" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_clubForm.Town" Label="Town" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_clubForm.Postcode" Label="Postcode" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_clubForm.Phone" Label="Phone" Variant="Variant.Outlined"
                              InputType="InputType.Telephone" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_clubForm.Email" Label="Email" Variant="Variant.Outlined"
                              InputType="InputType.Email" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_clubForm.Website" Label="Website" Variant="Variant.Outlined"
                              InputType="InputType.Url" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showClubDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveClub">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = true;
    private List<ClubDto> _clubs = [];
    private string _searchText = "";
    private List<int> _adminClubIds = [];
    private HashSet<int> _linkedClubIds = [];
    private HashSet<int> _pendingLinkClubIds = [];
    private HashSet<int> _pendingAdminRequestClubIds = [];

    private enum ClubLinkState { None, Pending, Linked, AdminPending, Administered }

    private ClubLinkState GetStatus(int clubId)
    {
        if (_adminClubIds.Contains(clubId)) return ClubLinkState.Administered;
        if (_pendingAdminRequestClubIds.Contains(clubId)) return ClubLinkState.AdminPending;
        if (_linkedClubIds.Contains(clubId)) return ClubLinkState.Linked;
        if (_pendingLinkClubIds.Contains(clubId)) return ClubLinkState.Pending;
        return ClubLinkState.None;
    }

    private bool _showClubDialog;
    private ClubForm _clubForm = new();

    private sealed class ClubForm
    {
        public string Name { get; set; } = "";
        public string? AddressLine1 { get; set; }
        public string? AddressLine2 { get; set; }
        public string? Town { get; set; }
        public string? Postcode { get; set; }
        public string? Phone { get; set; }
        public string? Email { get; set; }
        public string? Website { get; set; }
    }

    private bool FilterClubs(ClubDto club) =>
        string.IsNullOrWhiteSpace(_searchText) ||
        club.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        (club.Town ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        (club.Email ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadLinkState();
        await LoadClubs();
    }

    private async Task LoadLinkState()
    {
        var links = await ClubService.GetMyClubLinksAsync();
        _adminClubIds = links.AdminClubIds.ToList();
        _linkedClubIds = links.LinkedClubIds.ToHashSet();
        _pendingLinkClubIds = links.PendingClubIds.ToHashSet();
        _pendingAdminRequestClubIds = links.PendingAdminRequestClubIds.ToHashSet();
    }

    private async Task LoadClubs()
    {
        _loading = true;
        _clubs = await ClubService.GetClubsAsync();
        _loading = false;
    }

    private async Task RequestLink(ClubDto club)
    {
        if (!CurrentUser.IsAuthenticated)
        {
            SiteAlerts.Add("You must be signed in to request a link.", Severity.Warning);
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync(
            $"Request to link with {club.Name}?",
            $"This will send a request to the administrators of {club.Name}. " +
            "If they approve it, you will be added as a player on their roster. " +
            "You can cancel a pending request from this page at any time before it is approved.",
            yesText: "Send request", cancelText: "Cancel");

        if (confirmed != true) return;

        await ClubService.RequestClubLinkAsync(club.ClubId);
        _pendingLinkClubIds.Add(club.ClubId);
        SiteAlerts.Add($"Request sent to {club.Name}.", Severity.Success);
    }

    private async Task CancelRequest(ClubDto club)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            $"Cancel link request to {club.Name}?",
            "Your pending request will be deleted. You can submit a new one later if you change your mind.",
            yesText: "Delete request", cancelText: "Keep request");

        if (confirmed != true) return;

        await ClubService.CancelMyClubLinkRequestAsync(club.ClubId);
        _pendingLinkClubIds.Remove(club.ClubId);
        SiteAlerts.Add($"Request to {club.Name} cancelled.", Severity.Success);
    }

    private async Task RequestAdminRole(ClubDto club)
    {
        if (!CurrentUser.IsAuthenticated)
        {
            SiteAlerts.Add("You must be signed in to request admin access.", Severity.Warning);
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync(
            $"Request admin access to {club.Name}?",
            $"This will send a request to the site administrators for review. " +
            "You'll be notified by email when a decision is made.",
            yesText: "Send request", cancelText: "Cancel");

        if (confirmed != true) return;

        try
        {
            await ClubService.RequestClubAdminAsync(club.ClubId);
            _pendingAdminRequestClubIds.Add(club.ClubId);
            SiteAlerts.Add($"Admin request sent for {club.Name}.", Severity.Success);
        }
        catch (Exception ex)
        {
            SiteAlerts.Add(ex.Message, Severity.Error);
        }
    }

    private async Task CancelAdminRequest(ClubDto club)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            $"Cancel admin request for {club.Name}?",
            "Your pending admin request will be deleted.",
            yesText: "Delete request", cancelText: "Keep request");

        if (confirmed != true) return;

        await ClubService.CancelMyClubAdminRequestAsync(club.ClubId);
        _pendingAdminRequestClubIds.Remove(club.ClubId);
        SiteAlerts.Add($"Admin request for {club.Name} cancelled.", Severity.Success);
    }

    private void OpenAddDialog()
    {
        _clubForm = new ClubForm();
        _showClubDialog = true;
    }

    private async Task SaveClub()
    {
        if (string.IsNullOrWhiteSpace(_clubForm.Name)) return;
        var req = new SaveClubRequest(
            _clubForm.Name.Trim(),
            NullIfEmpty(_clubForm.AddressLine1),
            NullIfEmpty(_clubForm.AddressLine2),
            NullIfEmpty(_clubForm.Town),
            NullIfEmpty(_clubForm.Postcode),
            NullIfEmpty(_clubForm.Phone),
            NullIfEmpty(_clubForm.Email),
            NullIfEmpty(_clubForm.Website));

        await ClubService.CreateClubAsync(req);
        SiteAlerts.Add("Club added.", Severity.Success);
        _showClubDialog = false;
        await LoadClubs();
    }

    private async Task DeleteClub(ClubDto club)
    {
        await ClubService.DeleteClubAsync(club.ClubId);
        SiteAlerts.Add("Club deleted.", Severity.Warning);
        await LoadClubs();
    }

    private static string? NullIfEmpty(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();
}
