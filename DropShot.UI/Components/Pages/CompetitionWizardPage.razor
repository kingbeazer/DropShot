    // ── Post-save step handlers ─────────────────────────────────

    private void AddWizardAdmin()
    {
        var email = _newAdminEmail.Trim();
        if (string.IsNullOrEmpty(email)) return;
        if (_pendingAdminEmails.Contains(email, StringComparer.OrdinalIgnoreCase))
        {
            Snackbar.Add($"'{email}' is already in the list.", Severity.Info);
            return;
        }
        _pendingAdminEmails.Add(email);
        _newAdminEmail = "";
    }

    private void AddWizardDivision()
    {
        var name = _newDivisionName.Trim();
        if (string.IsNullOrEmpty(name)) return;
        _addedDivisions.Add(new WizardDivision { Name = name, Rank = _newDivisionRank });
        _newDivisionName = "";
        _newDivisionRank = (byte)(_newDivisionRank + 1);
    }

    private void AddDivisionWindow(WizardDivision div)
    {
        if (div.NewStart == null || div.NewEnd == null) return;
        div.Windows.Add(new WizardMatchWindow
        {
            DayOfWeek = div.NewDay,
            StartTime = div.NewStart.Value,
            EndTime = div.NewEnd.Value,
        });
    }

    private void AddCompetitionMatchWindow()
    {
        if (_newCompWindowStart == null || _newCompWindowEnd == null) return;
        _competitionMatchWindows.Add(new WizardMatchWindow
        {
            DayOfWeek = _newCompWindowDay,
            StartTime = _newCompWindowStart.Value,
            EndTime = _newCompWindowEnd.Value,
        });
    }

    private Task AddWizardCalendarExceptionAsync(SaveCalendarExceptionRequest req)
    {
        // Use a negative placeholder ID; will be created with real IDs on Finish.
        var placeholder = new CompetitionCalendarExceptionDto(
            CompetitionCalendarExceptionId: --_calendarExceptionPlaceholderId,
            CompetitionId: 0,
            CompetitionDivisionId: null,
            DivisionName: null,
            ExceptionDate: req.ExceptionDate,
            Note: req.Note);
        _wizardCalendarExceptions.Add(placeholder);
        Snackbar.Add($"Added exception for {req.ExceptionDate:dd MMM yyyy}.", Severity.Success);
        return Task.CompletedTask;
    }

    private Task DeleteWizardCalendarExceptionAsync(CompetitionCalendarExceptionDto ex)
    {
        _wizardCalendarExceptions.RemoveAll(e => e.CompetitionCalendarExceptionId == ex.CompetitionCalendarExceptionId);
        return Task.CompletedTask;
    }

    private void ToggleStage(StageType t, bool selected)
    {
        if (selected) _selectedStages.Add(t);
        else _selectedStages.Remove(t);
    }

    private void SaveStagesAndAdvance() => TryAdvance();

    private void OnRubberPresetChanged(string value)
    {
        _selectedRubberPresetKey = value;
    }


