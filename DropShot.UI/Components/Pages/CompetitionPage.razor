    private async Task SaveFixture()
    {
        var side1 = new[] { _fixtureForm.Player1Id, _fixtureForm.Player3Id }
            .Where(id => id.HasValue).Select(id => id!.Value).ToHashSet();
        var side2 = new[] { _fixtureForm.Player2Id, _fixtureForm.Player4Id }
            .Where(id => id.HasValue).Select(id => id!.Value).ToHashSet();
        if (side1.Overlaps(side2))
        {
            Snackbar.Add("A player cannot appear on both sides of a fixture.", Severity.Error);
            return;
        }

        if (!await ConfirmFixtureAssignmentAsync()) return;

        bool isTeamMatch = EffectivePersistedFormat() == CompetitionFormat.TeamMatch;
        var saveRequest = new SaveFixtureRequest(
            CompetitionStageId: _fixtureForm.CompetitionStageId,
            CourtId: isTeamMatch ? null : _fixtureForm.CourtId,
            ScheduledAt: _fixtureForm.ScheduledAt,
            FixtureLabel: _fixtureForm.FixtureLabel,
            RoundNumber: null,
            Player1Id: _fixtureForm.Player1Id,
            Player2Id: _fixtureForm.Player2Id,
            Player3Id: _fixtureForm.Player3Id,
            Player4Id: _fixtureForm.Player4Id,
            Status: _fixtureForm.Status,
            HomeTeamId: _fixtureForm.HomeTeamId,
            AwayTeamId: _fixtureForm.AwayTeamId,
            CourtPairId: isTeamMatch ? _fixtureForm.CourtPairId : null);

        await Admin.SaveFixtureAsync(Id, _editingFixture?.CompetitionFixtureId, saveRequest);
        await ReloadAfterServerMutationAsync();
        Snackbar.Add(_editingFixture == null ? "Fixture added." : "Fixture updated.", Severity.Success);
        _showFixtureDialog = false;
    }

    /// <summary>
    /// Runs the fixture-assignment eligibility + pairing rules for the currently
    /// edited fixture. Returns true if the caller should proceed. Any violations
    /// are surfaced as a confirm dialog; "Add anyway" logs an override and
    /// continues, "Cancel" aborts.
    /// </summary>
    private async Task<bool> ConfirmFixtureAssignmentAsync()
    {
        var result = await Admin.ConfirmFixtureAssignmentAsync(Id, new ConfirmFixtureAssignmentRequest(
            Player1Id: _fixtureForm.Player1Id,
            Player2Id: _fixtureForm.Player2Id,
            Player3Id: _fixtureForm.Player3Id,
            Player4Id: _fixtureForm.Player4Id,
            HomeTeamId: _fixtureForm.HomeTeamId,
            AwayTeamId: _fixtureForm.AwayTeamId));

        if (result.IsValid) return true;

        var body = "The following rule(s) would be broken:\n\n • "
            + string.Join("\n • ", result.Violations)
            + "\n\nSave this fixture anyway? This action will be logged.";
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Fixture has eligibility warnings",
            body,
            yesText: "Save anyway", cancelText: "Cancel");
        if (confirm != true) return false;
        Logger.LogWarning(
            "Admin override: fixture in competition {CompetitionId} saved with {Count} eligibility warning(s).",
            Id, result.Violations.Count);
        return true;
    }

