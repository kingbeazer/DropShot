    private async Task AddCustomRubberRow()
    {
        await Admin.AddCustomRubberRowAsync(Id);
        await ReloadRubberTemplateAsync();
    }

    private void OpenRubberRowEditor(RubberDef row)
    {
        _editingRubberRow = row;
        _editingRubberName = row.Name;
        _editingRubberCourt = row.CourtNumber;
        _editingRubberHomeCsv = string.Join(", ", row.HomeRoles);
        _editingRubberAwayCsv = string.Join(", ", row.AwayRoles);
        _showRubberRowDialog = true;
    }

    private async Task SaveRubberRowDialog()
    {
        if (_editingRubberRow == null) { _showRubberRowDialog = false; return; }

        var name = string.IsNullOrWhiteSpace(_editingRubberName) ? _editingRubberRow.Name : _editingRubberName.Trim();
        var court = _editingRubberCourt < 1 ? 1 : _editingRubberCourt;
        await Admin.SaveRubberRowAsync(Id, new SaveRubberRowRequest(
            RowId: null,
            Order: _editingRubberRow.Order,
            Name: name,
            CourtNumber: court,
            HomeRoles: ParseRoles(_editingRubberHomeCsv),
            AwayRoles: ParseRoles(_editingRubberAwayCsv)));

        _showRubberRowDialog = false;
        _editingRubberRow = null;
        await ReloadRubberTemplateAsync();
    }

    private async Task DeleteCustomRubberRow(int order)
    {
        await Admin.DeleteCustomRubberRowAsync(Id, order);
        await ReloadRubberTemplateAsync();
    }

    private async Task RevertToDefaultTemplate()
    {
        await Admin.RevertToDefaultTemplateAsync(Id);
        await ReloadRubberTemplateAsync();
        Snackbar.Add("Reverted to default rubber template.", Severity.Info);
    }

    private static List<string> ParseRoles(string csv) =>
        (csv ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

    private Task<IEnumerable<string>> SearchRoles(string value, CancellationToken _)
    {
        if (_availableRoles.Count == 0)
            return Task.FromResult<IEnumerable<string>>([]);
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(_availableRoles);
        return Task.FromResult<IEnumerable<string>>(
            _availableRoles.Where(r => r.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

