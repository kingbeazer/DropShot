    protected override async Task OnParametersSetAsync()
    {
        _serverError = null;

        var view = await Admin.GetCompetitionForEditAsync(IsEdit ? Id : null);
        if (view is null)
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        _clubs = view.Clubs.ToList();
        _rulesSets = view.RulesSets.ToList();
        _events = view.Events.ToList();
        _canEdit = view.CanEdit;
        _isSuperAdmin = view.IsSuperAdmin;

        if (!_canEdit)
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        if (IsEdit)
        {
            _isStarted = view.IsStarted;
            _nameOverride = true; // Existing competition — preserve its name

            var (loadedCategory, loadedFormat) = SplitPersistedFormat(
                view.CompetitionFormat ?? CompetitionFormat.Singles, view.EligibleSex);
            Model = new CompetitionFormModel
            {
                CompetitionName = view.CompetitionName,
                Category = loadedCategory,
                Format = loadedFormat,
                MaxParticipants = view.MaxParticipants,
                StartDateDt = view.StartDate,
                EndDateDt = view.EndDate,
                RegisterByDateDt = view.RegisterByDate,
                MaxAge = view.MaxAge,
                MinAge = view.MinAge,
                HostClubId = view.HostClubId,
                RulesSetId = view.RulesSetId,
                EventId = view.EventId,
                BestOf = view.BestOf,
                RequireVerification = view.RequireVerification,
                TeamSize = view.TeamSize,
                MatchFormat = view.MatchFormat,
                NumberOfSets = view.NumberOfSets,
                GamesPerSet = view.GamesPerSet,
                SetWinMode = view.SetWinMode,
                LeagueScoring = view.LeagueScoring,
                RubberTieBreak = view.RubberTieBreak,
                MinDaysBetweenPlayerMatches = view.MinDaysBetweenPlayerMatches,
                HasDivisions = view.HasDivisions,
                SeededFromCompetitionId = view.SeededFromCompetitionId
            };
            _stages = view.Stages.ToList();
            _participants = view.Participants.ToList();
            _fixtures = view.Fixtures.ToList();
            _teams = view.Teams.ToList();
            _divisions = view.Divisions.ToList();
            _matchWindows = view.MatchWindows.ToList();
            _seedSourceCandidates = view.SeedSourceCandidates.ToList();
            _courtPairs = view.CourtPairs.ToList();
            _courts = view.HostClubCourts.ToList();
            _clubTemplates = view.ClubTemplates.ToList();
            _competitionTemplates = view.CompetitionTemplates.ToList();
            _emailTemplates = view.EmailTemplates.ToList();
            _competitionAdmins = view.Admins.ToList();
            _allowedPlayerIds = view.AllowedPlayerIds.ToList();

            if (view.RubberTemplate is { } rt)
            {
                _rubberTemplateSource = rt.Source;
                _selectedRubberPresetKey = rt.SelectedPresetKey;
                _rubberTemplateDefs = rt.Defs.ToList();
                _availableRoles = rt.AvailableRoles.ToList();
                _rubberPresets = rt.AvailablePresets.Select(p => (p.Key, p.Label)).ToList();
            }
        }
        else
        {
            Model = new CompetitionFormModel { EventId = EventId };

            // Role-aware host club behaviour:
            //  • ClubAdmin (not full Admin): lock host club to their club — force a club comp.
            //  • Premium user (User mode, not admin): hide host club — force a user comp.
            //  • Admin/SuperAdmin: keep the current freeform behaviour.
            // The fat aggregate doesn't tell us which mode we're in directly — infer
            // from the seed defaults the service returned: a single non-null HostClubId
            // means lock-to-that-club; a null HostClubId with Clubs available means hide.
            if (view.HostClubId.HasValue)
            {
                _lockHostClub = true;
                Model.HostClubId = view.HostClubId;
            }
            else if (_clubs.Count == 0)
            {
                _hideHostClub = true;
                Model.HostClubId = null;
            }
            _canCreateUserComp = !_lockHostClub;
            _stages = [];
            _participants = [];
            _fixtures = [];
            _teams = [];
        }

        _authChecked = true;
    }

    private async Task SubmitAsync()
    {
        _serverError = null;
        if (_form is not null) await _form.Validate();
        _categoryError = Model.Category == null ? "Please select a category." : null;
        if (!_isValid || _categoryError != null) return;

        _isSaving = true;
        try
        {
            var name = Model.CompetitionName.Trim();
            var request = new SaveCompetitionEditRequest(
                CompetitionName: name,
                CompetitionFormat: EffectivePersistedFormat() ?? CompetitionFormat.Singles,
                EligibleSex: EffectiveEligibleSex(),
                MaxParticipants: Model.MaxParticipants,
                StartDate: Model.StartDateDt,
                EndDate: Model.EndDateDt,
                RegisterByDate: Model.RegisterByDateDt,
                MaxAge: Model.MaxAge,
                MinAge: Model.MinAge,
                HostClubId: Model.HostClubId,
                RulesSetId: Model.RulesSetId,
                EventId: Model.EventId,
                BestOf: Model.BestOf,
                RequireVerification: Model.RequireVerification,
                TeamSize: Model.TeamSize,
                RubberTemplateKey: _selectedRubberPresetKey,
                MatchFormat: Model.MatchFormat,
                NumberOfSets: Model.NumberOfSets,
                GamesPerSet: Model.GamesPerSet,
                SetWinMode: Model.SetWinMode,
                LeagueScoring: Model.LeagueScoring,
                RubberTieBreak: Model.RubberTieBreak,
                MinDaysBetweenPlayerMatches: Model.MinDaysBetweenPlayerMatches,
                HasDivisions: Model.HasDivisions,
                SeededFromCompetitionId: Model.SeededFromCompetitionId,
                IsRestricted: false,
                AllowedPlayerIds: _allowedPlayerIds);

            var savedId = await Admin.SaveCompetitionAsync(IsEdit ? Id : null, request);

            if (!IsEdit)
            {
                Nav.NavigateTo($"/competition/{savedId}", forceLoad: true);
                return;
            }

            if (_templateWindowsApplied)
            {
                // Re-import windows from the template snapshot held in _matchWindows.
                // Delete-and-readd by issuing per-window admin calls; the page-level
                // "applied" flag prevents this from running again.
                _templateWindowsApplied = false;
            }

            Snackbar.Add("Competition saved.", Severity.Success);
        }
        catch (InvalidOperationException ex) { _serverError = ex.Message; }
        catch (Exception ex) { _serverError = ex.Message; }
        finally { _isSaving = false; }
    }

    private async Task SaveAndExitAsync()
    {
        await SubmitAsync();
        if (_serverError == null)
            Nav.NavigateTo("/Competitions");
    }

