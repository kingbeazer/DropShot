<MudDialog @bind-Visible="_showCloneDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true })">
    <TitleContent>Clone Competition</TitleContent>
    <DialogContent>
