@using DropShot.Shared.Dtos
@using DropShot.UI.Services
@using Microsoft.AspNetCore.SignalR.Client
@using MudBlazor

@inject IScoreboardService Scoreboard
@inject IScoreboardHubFactory HubFactory

@* Routing + render mode + auth + MudProviders supplied by host shims. *@

<MudText Typo="Typo.h4" Class="mb-2">Display Control</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Control the scoreboard display for courts you manage. Changes are pushed live to all scoreboard screens showing that court.
</MudText>

@if (_courts.Count == 0 && _loaded)
{
    <MudAlert Severity="Severity.Info">No courts available for your account.</MudAlert>
}

<MudGrid>
    @foreach (var court in _courts)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@court.ClubName</MudText>
                        <MudText Typo="Typo.subtitle2" Style="color: var(--mud-palette-text-secondary);">@court.CourtName</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIcon Icon="@Icons.Material.Filled.Tv" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudSwitch T="bool" Value="GetFullscreen(court.CourtId)"
                               ValueChanged="@(v => ToggleFullscreen(court.CourtId, v))"
                               Label="Fullscreen" Color="Color.Primary" />
                    <MudSelect T="string" Value="GetLayout(court.CourtId)"
                               ValueChanged="@(v => ChangeLayout(court.CourtId, v))"
                               Label="Layout" Variant="Variant.Outlined" Class="mt-2">
                        <MudSelectItem T="string" Value=@("default")>Default</MudSelectItem>
                        <MudSelectItem T="string" Value=@("wimbledon")>Wimbledon</MudSelectItem>
                    </MudSelect>

                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-1">YouTube Live Stream</MudText>
                    <MudTextField T="string" Value="GetStreamUrl(court.CourtId)"
                                  ValueChanged="@(v => ChangeStreamUrl(court.CourtId, v))"
                                  Label="YouTube URL" Variant="Variant.Outlined"
                                  Placeholder="https://youtube.com/watch?v=... or embed URL"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Custom.Brands.YouTube"
                                  Immediate="true"
                                  Class="mt-2" />
                    <MudSwitch T="bool" Value="GetStreamEnabled(court.CourtId)"
                               ValueChanged="@(v => ToggleStream(court.CourtId, v))"
                               Label="Show Live Stream" Color="Color.Error" Class="mt-1"
                               Disabled="@(string.IsNullOrWhiteSpace(GetStreamUrl(court.CourtId)))" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private HubConnection? _hub;
    private List<AdminCourtDisplaySettingDto> _courts = [];
    private Dictionary<int, bool> _fullscreenState = new();
    private Dictionary<int, string> _layoutState = new();
    private Dictionary<int, string> _streamUrlState = new();
    private Dictionary<int, bool> _streamEnabledState = new();
    private bool _loaded;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        _courts = await Scoreboard.GetAdminCourtDisplaySettingsAsync();

        foreach (var court in _courts)
        {
            _fullscreenState[court.CourtId] = court.Fullscreen;
            _layoutState[court.CourtId] = court.Layout;
            _streamUrlState[court.CourtId] = court.LiveStreamUrl ?? "";
            _streamEnabledState[court.CourtId] = court.ShowLiveStream;
        }

        _loaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hub = HubFactory.Create();

            // Listen for display commands from other admins or scoreboard viewers
            _hub.On<int, string, string>("ReceiveDisplayCommand", async (courtId, command, value) =>
            {
                await ReloadSettingsFromServerAsync();
                await InvokeAsync(StateHasChanged);
            });

            await _hub.StartAsync();

            foreach (var court in _courts)
            {
                await _hub.SendAsync("JoinCourtGroup", court.CourtId);
            }
        }
    }

    private bool GetFullscreen(int courtId) => _fullscreenState.GetValueOrDefault(courtId);
    private string GetLayout(int courtId) => _layoutState.GetValueOrDefault(courtId, "default");
    private string GetStreamUrl(int courtId) => _streamUrlState.GetValueOrDefault(courtId, "");
    private bool GetStreamEnabled(int courtId) => _streamEnabledState.GetValueOrDefault(courtId);

    private async Task ToggleFullscreen(int courtId, bool value)
    {
        _fullscreenState[courtId] = value;
        await SaveSettingAsync(courtId);
        if (_hub?.State == HubConnectionState.Connected)
            await _hub.SendAsync("SendDisplayCommand", courtId, "setFullscreen", value.ToString().ToLower());
    }

    private async Task ChangeLayout(int courtId, string layout)
    {
        _layoutState[courtId] = layout;
        await SaveSettingAsync(courtId);
        if (_hub?.State == HubConnectionState.Connected)
            await _hub.SendAsync("SendDisplayCommand", courtId, "setLayout", layout);
    }

    private async Task ChangeStreamUrl(int courtId, string url)
    {
        _streamUrlState[courtId] = url;

        // Auto-disable stream if URL is cleared
        if (string.IsNullOrWhiteSpace(url) && _streamEnabledState.GetValueOrDefault(courtId))
            _streamEnabledState[courtId] = false;

        await SaveSettingAsync(courtId);
        if (_hub?.State == HubConnectionState.Connected)
        {
            await _hub.SendAsync("SendDisplayCommand", courtId, "setStreamUrl", url ?? "");
            if (string.IsNullOrWhiteSpace(url))
                await _hub.SendAsync("SendDisplayCommand", courtId, "setStreamEnabled", "false");
        }
    }

    private async Task ToggleStream(int courtId, bool enabled)
    {
        _streamEnabledState[courtId] = enabled;
        await SaveSettingAsync(courtId);
        if (_hub?.State == HubConnectionState.Connected)
            await _hub.SendAsync("SendDisplayCommand", courtId, "setStreamEnabled", enabled.ToString().ToLower());
    }

    private async Task SaveSettingAsync(int courtId)
    {
        _isSaving = true;
        try
        {
            await Scoreboard.UpdateDisplaySettingAsync(courtId, new UpdateDisplaySettingRequest(
                Layout: _layoutState.GetValueOrDefault(courtId, "default"),
                Fullscreen: _fullscreenState.GetValueOrDefault(courtId),
                LiveStreamUrl: _streamUrlState.GetValueOrDefault(courtId, ""),
                ShowLiveStream: _streamEnabledState.GetValueOrDefault(courtId)));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ReloadSettingsFromServerAsync()
    {
        if (_isSaving) return; // ignore our own echoed SignalR messages

        var refreshed = await Scoreboard.GetAdminCourtDisplaySettingsAsync();
        var byId = refreshed.ToDictionary(c => c.CourtId);

        foreach (var court in _courts)
        {
            if (byId.TryGetValue(court.CourtId, out var s))
            {
                _fullscreenState[court.CourtId] = s.Fullscreen;
                _layoutState[court.CourtId] = s.Layout;
                _streamUrlState[court.CourtId] = s.LiveStreamUrl ?? "";
                _streamEnabledState[court.CourtId] = s.ShowLiveStream;
            }
        }
    }
}
